# ── Supabase local ────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values from: supabase status

# Used by Next.js (inlined at build time) AND as a fallback by the test runner.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from supabase status>

# Server-only — NEVER import in browser code.
# Required by the test suite (RLS isolation tests).
SUPABASE_SERVICE_ROLE_KEY=<service_role key from supabase status>
